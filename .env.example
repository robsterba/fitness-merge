# Copy to .env and adjust. docker-compose passes these to the api service.

DATABASE_URL=postgresql+psycopg://fitness:fitness@localhost:5432/fitness
IMPORT_DIR=./imports

# Optional Strava (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback
PUBLIC_BASE_URL=http://localhost:8000

# Optional: matching (same workout across Strava + files)
# MATCH_START_TOLERANCE_SECONDS=900
# MATCH_DURATION_TOLERANCE_RATIO=0.12
